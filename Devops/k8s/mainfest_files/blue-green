apiVersion: apps/v1
kind: Deployment
metadata:
  name: blue
spec:
  replicas: 3
  selector:
    matchLabels:
      app: blue
  template:
    metadata:
      labels:
        app: blue
    spec:
      containers:
        - name: blue
          image: abhipraydh96/studentapp:v1
          ports:
            - containerPort: 80



apiVersion: apps/v1
kind: Deployment
metadata:
  name: green
spec:
  replicas: 3
  selector:
    matchLabels:
      app: green
  template:
    metadata:
      labels:
        app: green
    spec:
      containers:
        - name: green
          image: abhipraydh96/studentapp:v2
          ports:
            - containerPort: 80


---
apiVersion: v1
kind: Service
metadata: 
  name: svc-bg
spec:
  selector:
    app: blue
  ports:
    - protocol: "TCP"
      port: 80
      targetPort: 80 
  type: NodePort



